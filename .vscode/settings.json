{
  "deno.enablePaths": [
    "supabase/functions"
  ],
  "deno.importMap": "./supabase/functions/deno.json", // Add this line (or deno.json if that's what your CLI generated)
  "deno.lint": true,
  "deno.unstable": [
    "bare-node-builtins",
    "byonm",
    "sloppy-imports",
    "unsafe-proto",
    "webgpu",
    "broadcast-channel",
    "worker-options",
    "cron",
    "kv",
    "ffi",
    "fs",
    "http",
    "net"
  ],
  "[typescript]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  }
}
